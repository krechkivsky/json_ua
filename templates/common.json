{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "Common GeoJSON schemas",
  "$defs": {
    "NonEmptyString": {
      "type": "string",
      "minLength": 1
    },

    "GeoJSONBBox": {
      "type": "array",
      "minItems": 4,
      "items": { "type": "number" }
    },

    "Position": {
      "type": "array",
      "minItems": 2,
      "maxItems": 3,
      "items": { "type": "number" }
    },

    "Point": {
      "type": "object",
      "required": ["type", "coordinates"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "Point" },
        "bbox": { "$ref": "#/$defs/GeoJSONBBox" },
        "coordinates": { "$ref": "#/$defs/Position" }
      }
    },

    "LineString": {
      "type": "object",
      "required": ["type", "coordinates"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "LineString" },
        "bbox": { "$ref": "#/$defs/GeoJSONBBox" },
        "coordinates": {
          "type": "array",
          "minItems": 2,
          "items": { "$ref": "#/$defs/Position" }
        }
      }
    },

    "Polygon": {
      "type": "object",
      "required": ["type", "coordinates"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "Polygon" },
        "bbox": { "$ref": "#/$defs/GeoJSONBBox" },
        "coordinates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 4,
            "items": { "$ref": "#/$defs/Position" }
          }
        }
      }
    },

    "MultiPolygon": {
      "type": "object",
      "required": ["type", "coordinates"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "MultiPolygon" },
        "bbox": { "$ref": "#/$defs/GeoJSONBBox" },
        "coordinates": {
          "type": "array",
          "minItems": 1,
          "items": {
            "type": "array",
            "minItems": 1,
            "items": {
              "type": "array",
              "minItems": 4,
              "items": { "$ref": "#/$defs/Position" }
            }
          }
        }
      }
    },

    "Geometry": {
      "oneOf": [
        { "$ref": "#/$defs/Point" },
        { "$ref": "#/$defs/LineString" },
        { "$ref": "#/$defs/Polygon" },
        { "$ref": "#/$defs/MultiPolygon" }
      ]
    },

    "FeatureBase": {
      "type": "object",
      "required": ["type", "properties", "geometry"],
      "properties": {
        "type": { "const": "Feature" },
        "id": {},
        "bbox": { "$ref": "#/$defs/GeoJSONBBox" },
        "properties": { "type": "object" },
        "geometry": { "$ref": "#/$defs/Geometry" }
      }
    },

    "FeatureCollectionBase": {
      "type": "object",
      "required": ["type", "features"],
      "properties": {
        "type": { "const": "FeatureCollection" },
        "bbox": { "$ref": "#/$defs/GeoJSONBBox" },
        "features": {
          "type": "array",
          "items": { "$ref": "#/$defs/FeatureBase" }
        }
      }
    }
  }
}